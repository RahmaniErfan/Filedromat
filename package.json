{
  "name": "filedromat",
  "version": "0.1.0",
  "description": "A cross-platform local file organizer that uses AI to propose folder structures.",
  "main": "dist/index.js",
  "bin": {
    "filedromat": "./bin/filedromat.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "web:dev": "npm run dev --prefix web"
  },
  "keywords": [
    "file",
    "organizer",
    "ai",
    "cli",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^1.1.9",
    "@clack/prompts": "^0.9.1",
    "ai": "^4.1.45",
    "dotenv": "^16.4.7",
    "hono": "^4.7.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
