{
  "name": "filedromat",
  "version": "1.0.0",
  "description": "A cross-platform local file organizer that uses AI to propose folder structures.",
  "main": "dist/index.js",
  "bin": {
    "filedromat": "./bin/filedromat.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "server:dev": "tsx src/server.ts",
    "web:dev": "npm run dev --prefix web",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run web:dev\""
  },
  "keywords": [
    "file",
    "organizer",
    "ai",
    "cli",
    "automation"
  ],
  "author": "Erfan Rahmani",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^1.1.9",
    "@clack/prompts": "^0.9.1",
    "@hono/node-server": "^1.19.11",
    "ai": "^4.1.45",
    "dotenv": "^16.4.7",
    "hono": "^4.7.2",
    "ink": "npm:@jrichman/ink@^6.5.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
